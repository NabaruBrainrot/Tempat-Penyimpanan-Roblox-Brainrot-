local function createBtn(txt, pos)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.35, 0, 0, 35)
    btn.Position = pos
    btn.Text = txt
    btn.BackgroundColor3 = Color3.fromRGB(70, 70, 70)
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.TextSize = 14
    btn.Parent = frame
    return btn
end

local getKeyBtn = createBtn("GET KEY", UDim2.new(0.1, 0, 0.68, 0))
getKeyBtn.MouseButton1Click:Connect(function()
    setclipboard(linkKeyURL)

    -- NOTIFIKASI TAMBAHAN
    game.StarterGui:SetCore("SendNotification", {
        Title = "Copied",
        Text = "Link copied to clipboard!",
        Duration = 3
    })

    getKeyBtn.Text = "GET KEY"
    task.wait(1)
    getKeyBtn.Text = "GET KEY"
end)

local isChecking = false
local verifyBtn = createBtn("ENTER", UDim2.new(0.55, 0, 0.68, 0))
verifyBtn.MouseButton1Click:Connect(function()
    if isChecking or textbox.Text == "" then return end
    isChecking = true
    
    if string.lower(textbox.Text) == string.lower(kodeRahasia) then
        verifyBtn.Text = "Verifying..."
        pcall(function() writefile(statusFile, "verified;" .. tostring(tick())) end)
        task.wait(0.5)
        gui:Destroy()
        pcall(function() loadstring(game:HttpGet("https://raw.githubusercontent.com/NabaruBrainrot/Tempat-Penyimpanan-Roblox-Brainrot-/refs/heads/main/MuscleMaster2.lua"))() end)
    else
        infoLabel.Visible = true
        task.wait(1.5)
        infoLabel.Visible = false
        isChecking = false
    end
end)