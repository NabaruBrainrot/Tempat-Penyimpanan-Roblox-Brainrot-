local statusFile = "fadhen_code.TheJusDd2inginBrsa3sswh"
local trialFile = "fadhen3_trial.tmp"
local KEY_VALID_SECONDS = 432000 -- 24 jam
local TRIAL_DURATION = 3600 -- 30 menit

local isfile = isfile or function() return false end
local readfile = readfile or function() return "" end
local writefile = writefile or function() end

local function isKeyStillValid()
    if not isfile(statusFile) then return false end
    local success, data = pcall(readfile, statusFile)
    if not success then return false end
    local split = string.split(data, ";")
    if split[1] ~= "verified" then return false end
    local timestamp = tonumber(split[2])
    if not timestamp then return false end
    return (tick() - timestamp) <= KEY_VALID_SECONDS
end

-- Cek key valid
if isKeyStillValid() then
    pcall(function()
        loadstring(game:HttpGet("https://raw.githubusercontent.com/NabaruBrainrot/Tempat-Penyimpanan-Roblox-Brainrot-/refs/heads/main/MuscleMaster2.lua"))()
    end)
    return
end

-- Cek trial: belum pernah → tulis & langsung load; masih aktif → langsung load
if not isfile(trialFile) then
    -- Pertama kali: tulis timestamp trial
    pcall(function() writefile(trialFile, tostring(tick())) end)
    pcall(function()
        loadstring(game:HttpGet("https://raw.githubusercontent.com/NabaruBrainrot/Tempat-Penyimpanan-Roblox-Brainrot-/refs/heads/main/MuscleMaster2.lua"))()
    end)
    return
else
    -- Sudah pernah: cek apakah 30 menit belum habis
    local ok, data = pcall(readfile, trialFile)
    if ok then
        local timestamp = tonumber(data)
        if timestamp and (tick() - timestamp) <= TRIAL_DURATION then
            pcall(function()
                loadstring(game:HttpGet("https://raw.githubusercontent.com/NabaruBrainrot/Tempat-Penyimpanan-Roblox-Brainrot-/refs/heads/main/MuscleMaster2.lua"))()
            end)
            return
        end
    end
end

