local function getPetsFolder()
    return player.PlayerGui:WaitForChild("LuckyOpenPets")
        :WaitForChild(selectedFolder)
        :WaitForChild("PetsMenuFrame")
        :WaitForChild("PetsScrolllist")
end

local function refreshPetDrop()
    clearScroll()
    positionDropBelow(petBtn)

    local ok, petsFolder = pcall(getPetsFolder)
    if not ok then
        makeDropItem("Missing Data", Color3.fromRGB(220, 100, 100), function() end)
        scroll.CanvasSize = UDim2.new(0, 0, 0, 44)
        openDrop(44)
        return
    end

    local petLabels = {}
    for _, v in pairs(petsFolder:GetChildren()) do
        if v:IsA("ImageLabel") then
            table.insert(petLabels, v)
        end
    end
    table.sort(petLabels, function(a, b) return a.Name < b.Name end)

    if #petLabels == 0 then
        makeDropItem("Empty List", Color3.fromRGB(220, 180, 100), function() end)
        scroll.CanvasSize = UDim2.new(0, 0, 0, 44)
        openDrop(44)
        return
    end

    for _, petLabel in pairs(petLabels) do
        local petName = petLabel.Name
        local isSelected = selectedPets[petName] ~= nil

        local row = Instance.new("Frame")
        row.Size = UDim2.new(1, 0, 0, 32)
        row.BackgroundColor3 = isSelected and Color3.fromRGB(35, 45, 55) or Color3.fromRGB(28, 28, 38)
        row.BorderSizePixel = 0
        row.ZIndex = 10
        row.Parent = scroll

        local rowCorner = Instance.new("UICorner")
        rowCorner.CornerRadius = UDim.new(0, 4)
        rowCorner.Parent = row

        local imgClone = petLabel:Clone()
        imgClone.Size = UDim2.new(0, 24, 0, 24)
        imgClone.Position = UDim2.new(0, 4, 0.5, -12)
        imgClone.BackgroundTransparency = 1
        imgClone.BorderSizePixel = 0
        imgClone.ZIndex = 11
        imgClone.Parent = row

        local checkIcon = Instance.new("ImageLabel")
        checkIcon.Size = UDim2.new(0, 12, 0, 12)
        checkIcon.Position = UDim2.new(1, -20, 0.5, -6)
        checkIcon.BackgroundTransparency = 1
        checkIcon.Image = isSelected and "rbxassetid://6031094667" or "rbxassetid://6031094670"
        checkIcon.ImageColor3 = isSelected and Color3.fromRGB(100, 200, 120) or Color3.fromRGB(100, 100, 120)
        checkIcon.ZIndex = 11
        checkIcon.Parent = row

        local nameLabel = Instance.new("TextLabel")
        nameLabel.Size = UDim2.new(1, -60, 1, 0)
        nameLabel.Position = UDim2.new(0, 34, 0, 0)
        nameLabel.BackgroundTransparency = 1
        nameLabel.Text = petName
        nameLabel.TextColor3 = isSelected and Color3.fromRGB(240, 240, 250) or Color3.fromRGB(180, 180, 200)
        nameLabel.TextXAlignment = Enum.TextXAlignment.Left
        nameLabel.Font = Enum.Font.Gotham
        nameLabel.TextSize = 11
        nameLabel.TextTruncate = Enum.TextTruncate.AtEnd
        nameLabel.ZIndex = 11
        nameLabel.Parent = row

        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, 0, 1, 0)
        btn.BackgroundTransparency = 1
        btn.Text = ""
        btn.ZIndex = 12
        btn.Parent = row

        btn.MouseEnter:Connect(function()
            row.BackgroundColor3 = selectedPets[petName] and Color3.fromRGB(45, 55, 65) or Color3.fromRGB(38, 38, 48)
        end)
        btn.MouseLeave:Connect(function()
            row.BackgroundColor3 = selectedPets[petName] and Color3.fromRGB(35, 45, 55) or Color3.fromRGB(28, 28, 38)
        end)
        btn.MouseButton1Click:Connect(function()
            if selectedPets[petName] then
                selectedPets[petName] = nil
                nameLabel.TextColor3 = Color3.fromRGB(180, 180, 200)
                row.BackgroundColor3 = Color3.fromRGB(28, 28, 38)
                checkIcon.Image = "rbxassetid://6031094670"
                checkIcon.ImageColor3 = Color3.fromRGB(100, 100, 120)
            else
                selectedPets[petName] = true
                nameLabel.TextColor3 = Color3.fromRGB(240, 240, 250)
                row.BackgroundColor3 = Color3.fromRGB(35, 45, 55)
                checkIcon.Image = "rbxassetid://6031094667"
                checkIcon.ImageColor3 = Color3.fromRGB(100, 200, 120)
            end
        end)
    end

    scroll.CanvasSize = UDim2.new(0, 0, 0, #petLabels * 36 + 16)
    openDrop(#petLabels * 36 + 16)
end

