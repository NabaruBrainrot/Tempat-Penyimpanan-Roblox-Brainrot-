local function positionDropBelow(btn)
    local absPos = btn.AbsolutePosition
    local absSize = btn.AbsoluteSize
    dropFrame.Position = UDim2.new(0, absPos.X, 0, absPos.Y + absSize.Y + 6)
end

local function openDrop(height)
    dropFrame.Visible = true
    TweenService:Create(dropFrame, TweenInfo.new(0.2, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
        Size = UDim2.new(0, 190, 0, math.min(height, 200))
    }):Play()
end

local function closeDrop()
    TweenService:Create(dropFrame, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        Size = UDim2.new(0, 190, 0, 0)
    }):Play()
    task.delay(0.16, function() dropFrame.Visible = false end)
end

local function clearScroll()
    for _, c in pairs(scroll:GetChildren()) do
        if not c:IsA("UIListLayout") and not c:IsA("UIPadding") then
            c:Destroy()
        end
    end
end

local function makeDropItem(text, color, onClick)
    local item = Instance.new("TextButton")
    item.Size = UDim2.new(1, 0, 0, 28)
    item.BackgroundColor3 = Color3.fromRGB(28, 28, 38)
    item.BorderSizePixel = 0
    item.Text = "  " .. text
    item.TextColor3 = color or Color3.fromRGB(200, 200, 220)
    item.Font = Enum.Font.Gotham
    item.TextSize = 11
    item.TextXAlignment = Enum.TextXAlignment.Left
    item.AutoButtonColor = false
    item.ZIndex = 10
    item.Parent = scroll
    
    local ic = Instance.new("UICorner")
    ic.CornerRadius = UDim.new(0, 4)
    ic.Parent = item
    
    item.MouseEnter:Connect(function() item.BackgroundColor3 = Color3.fromRGB(38, 38, 48) end)
    item.MouseLeave:Connect(function() item.BackgroundColor3 = Color3.fromRGB(28, 28, 38) end)
    item.MouseButton1Click:Connect(onClick)
    return item
end

